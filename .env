# Slack Configuration
# Get these from https://api.slack.com/apps
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Server Configuration
PORT=3000
NODE_ENV=development

# Data Source Toggle
# Set to 'true' to use dummy JSON data for testing (no MongoDB required)
# Set to 'false' to use MongoDB database
USE_DUMMY_DATA=true

# MongoDB Configuration (used only when USE_DUMMY_DATA=false)
MONGODB_URI=mongodb://localhost:27017/slack-event-manager
MONGODB_DB_NAME=slack-event-manager

# Optional: MongoDB Atlas Search (if using Atlas)
# MONGODB_ATLAS_SEARCH_INDEX_NAME=event-search
